    "content": "use assignment9;\nCREATE TABLE EMPLOYEE (\n    ENo INT PRIMARY KEY,\n    FName VARCHAR(50),\n    Age INT,\n    Grade VARCHAR(50),\n    Salary DECIMAL(10, 2)\n);\nDELIMITER //\n\nCREATE PROCEDURE UpdateEmployeeSalaries()\nBEGIN\n    DECLARE e_no INT;\n    DECLARE e_grade VARCHAR(50);\n    DECLARE done INT DEFAULT FALSE;\n    DECLARE increment_val INT;\n\n    DECLARE Emp_Cursor CURSOR FOR SELECT ENo, Grade FROM EMPLOYEE;\n\n    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;\n\n    OPEN Emp_Cursor;\n\n    read_loop: LOOP\n        FETCH Emp_Cursor INTO e_no, e_grade;\n\n        IF done THEN\n            LEAVE read_loop;\n        END IF;\n\n        SET increment_val = CASE \n            WHEN e_grade = 'Asst. prof' THEN 10000\n            WHEN e_grade = 'Associate Prof' THEN 20000\n            WHEN e_grade = 'Professor' THEN 30000\n            ELSE 0\n        END;\n\n        UPDATE EMPLOYEE \n        SET Salary = Salary + increment_val \n        WHERE ENo = e_no;\n\n    END LOOP;\n\n    CLOSE Emp_Cursor;\nEND //\n\nDELIMITER ;\nINSERT INTO EMPLOYEE VALUES (101, 'Abhinandan', 20, 'Asst. prof', 50000);\nINSERT INTO EMPLOYEE VALUES (102, 'Sinha', 35, 'Associate Prof', 70000);\nINSERT INTO EMPLOYEE VALUES (103, 'Pandit', 45, 'Professor', 90000);\nCALL UpdateEmployeeSalaries();\nSELECT * FROM EMPLOYEE;\n\nCREATE TABLE Customer (\n    cust_id INT PRIMARY KEY,\n    Principal_amount DECIMAL(15, 2),\n    Rate_of_interest DECIMAL(5, 2),\n    No_of_Years INT\n);\n\nCREATE TABLE TEMPLIST (\n    cust_id INT,\n    Interest_Amount DECIMAL(15, 2)\n);\nDELIMITER //\n\nCREATE PROCEDURE CalculateAndLogInterest()\nBEGIN\n    DECLARE c_id INT;\n    DECLARE p_amt DECIMAL(15, 2);\n    DECLARE r_rate DECIMAL(5, 2);\n    DECLARE n_years INT;\n    DECLARE calc_interest DECIMAL(15, 2);\n    DECLARE done INT DEFAULT FALSE;\n\n    DECLARE interest_cursor CURSOR FOR SELECT cust_id, Principal_amount, Rate_of_interest, No_of_Years FROM Customer;\n    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;\n\n    OPEN interest_cursor;\n\n    read_loop: LOOP\n        FETCH interest_cursor INTO c_id, p_amt, r_rate, n_years;\n\n        IF done THEN\n            LEAVE read_loop;\n        END IF;\n        SET calc_interest = p_amt * POW((1 + r_rate / 100), n_years) - p_amt;\n        INSERT INTO TEMPLIST (cust_id, Interest_Amount)\n        VALUES (c_id, calc_interest);\n\n    END LOOP;\n\n    CLOSE interest_cursor;\nEND //\n\nDELIMITER ;\nINSERT INTO Customer VALUES (1, 10000, 5.0, 2);\nINSERT INTO Customer VALUES (2, 5000, 10.0, 3);\nCALL CalculateAndLogInterest();\nSELECT * FROM TEMPLIST;\n\nCREATE TABLE sales_tax_rate (\n    state CHAR(2),\n    tax_rate DECIMAL(5, 4) \n);\n\nCREATE TABLE customer (\n    c_name VARCHAR(100),\n    product_purchased VARCHAR(100),\n    price_of_product DECIMAL(10, 2),\n    city VARCHAR(100),\n    state CHAR(2)\n);\n\nCREATE TABLE customer_tax_report (\n    c_name VARCHAR(100),\n    city VARCHAR(100),\n    state CHAR(2),\n    tax_paid DECIMAL(10, 2)\n);\nDELIMITER //\n\nCREATE PROCEDURE ComputeSalesTax()\nBEGIN\n    DECLARE cust_name VARCHAR(100);\n    DECLARE cust_city VARCHAR(100);\n    DECLARE cust_state CHAR(2);\n    DECLARE prod_price DECIMAL(10, 2);\n    DECLARE s_tax_rate DECIMAL(5, 4);\n    DECLARE calculated_tax DECIMAL(10, 2);\n    DECLARE done INT DEFAULT FALSE;\n\n    DECLARE tax_cursor CURSOR FOR \n        SELECT customer.c_name, customer.city, customer.state, customer.price_of_product, sales_tax_rate.tax_rate\n        FROM customer\n        JOIN sales_tax_rate ON customer.state = sales_tax_rate.state;\n\n    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;\n\n    OPEN tax_cursor;\n\n    read_loop: LOOP\n        FETCH tax_cursor INTO cust_name, cust_city, cust_state, prod_price, s_tax_rate;\n        IF done THEN\n            LEAVE read_loop;\n        END IF;\n\n        SET calculated_tax = prod_price * s_tax_rate;\n\n        INSERT INTO customer_tax_report (c_name, city, state, tax_paid)\n        VALUES (cust_name, cust_city, cust_state, calculated_tax);\n    END LOOP;\n\n    CLOSE tax_cursor;\nEND //\n\nDELIMITER ;\nDROP TABLE IF EXISTS customer;\n\n-- 2. Create it with the exact column names we need\nCREATE TABLE customer (\n    c_name VARCHAR(100),\n    product_purchased VARCHAR(100),\n    price_of_product DECIMAL(10, 2),\n    city VARCHAR(100),\n    state CHAR(2)\n);\nINSERT INTO customer (c_name, product_purchased, price_of_product, city, state) \nVALUES ('Abhinandan', 'Laptop', 1200.00, 'NYC', 'NY');\n\nINSERT INTO customer (c_name, product_purchased, price_of_product, city, state) \nVALUES ('Sinha', 'Phone', 800.00, 'Austin', 'TX');\n\nSELECT * FROM customer;\nCREATE TABLE customer_tax_report (\n    c_name VARCHAR(100),\n    city VARCHAR(100),\n    state CHAR(2),\n    tax_paid DECIMAL(10, 2)\n);\nCALL ComputeSalesTax();\nselect * from customer_tax_report;\ndrop table Customer;;\n-- Source table\nCREATE TABLE Customer (\n    cust_id INT PRIMARY KEY,\n    Principal_amount DECIMAL(15, 2),\n    Rate_of_interest DECIMAL(5, 2),\n    No_of_Years INT\n);\n\n-- Target table for the results\nCREATE TABLE TEMPLIST (\n    cust_id INT,\n    Interest_Amount DECIMAL(15, 2)\n);\nDELIMITER //\n\nCREATE PROCEDURE CalculateInterestCursor()\nBEGIN\n\n    DECLARE c_id INT;\n    DECLARE p_amt DECIMAL(15, 2);\n    DECLARE r_rate DECIMAL(5, 2);\n    DECLARE n_years INT;\n    DECLARE compound_int DECIMAL(15, 2);\n    DECLARE simple_int DECIMAL(15, 2);\n    DECLARE done INT DEFAULT FALSE;\n\n\n    DECLARE cur CURSOR FOR \n        SELECT cust_id, Principal_amount, Rate_of_interest, No_of_Years FROM Customer;\n\n\n    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;\n\n    OPEN cur;\n\n    read_loop: LOOP\n        FETCH cur INTO c_id, p_amt, r_rate, n_years;\n        IF done THEN\n            LEAVE read_loop;\n        END IF;\n\n\n        SET compound_int = p_amt * POW((1 + r_rate / 100), n_years) - p_amt;\n\n\n        SET simple_int = (p_amt * r_rate * n_years) / 100;\n\n        INSERT INTO TEMPLIST (cust_id, Interest_Amount)\n        VALUES (c_id, simple_int);\n\n    END LOOP;\n\n    CLOSE cur;\nEND //\n\nDELIMITER ;\nINSERT INTO Customer VALUES (1, 5000.00, 5.0, 3);\nINSERT INTO Customer VALUES (2, 12000.00, 7.5, 5);\nCALL CalculateInterestCursor();\nSELECT * FROM TEMPLIST;\n",

    "content": "USE company\ncreate database company;\ncreate table EMP(EMPNO INT,ENAME VARCHAR(30),JOB VARCHAR(30),MGR INT,HIREDATE DATE,SAL FLOAT,COMM INT,DEPTNO INT);\nCREATE TABLE DEPT(DEPTNO INT,DNAME VARCHAR(30),LOC VARCHAR(30));\ninsert into emp values(7499,'Allen','Salesman',7698,'1981-02-20',1600,300,30);\ninsert into dept values(40,'Operations','Boston');\nselect distinct job from emp;\ndelete from emp where HIREDATE BETWEEN '1980-01-01' AND '1980-01-31';\nupdate emp set sal=sal+0.2*sal where job='Manager';\nselect * from emp where deptno <> 30 AND deptno <> 40 AND deptno <> 50;\nselect distinct job from emp;\nSELECT ename FROM emp WHERE comm IS NULL OR comm = 0;\nselect ename from emp where ename like 's%' OR ename like '%s';\nselect * from emp where ename like '_a%';\nselect count(*) as number_of_employees from emp;\nSELECT DATE_FORMAT(hiredate, '%M %e, %Y') FROM emp;\nSELECT * FROM emp WHERE job = 'SALESMAN' AND comm BETWEEN 200 AND 500;\n#Queries set 4 from here on\nSELECT ename FROM emp WHERE TIMESTAMPDIFF(YEAR, hiredate, CURDATE()) > 2;\nSELECT * FROM emp ORDER BY sal;\nSELECT * FROM emp WHERE sal > (SELECT sal FROM emp WHERE ename = 'SMITH');\nUPDATE emp SET sal = sal * 1.10 WHERE empno = 7499;\nSELECT * FROM emp WHERE sal BETWEEN 10000 AND 25000;\nSELECT ename FROM emp WHERE comm IS NULL OR comm = 0;\nUPDATE emp SET sal = sal * 1.10 WHERE job = 'CLERK';\nSELECT job, SUM(sal), MAX(sal), MIN(sal), AVG(sal) \nFROM emp GROUP BY job;\nDELETE FROM emp WHERE ename LIKE 'P%';\nSELECT * FROM emp WHERE job = 'CLERK' AND comm > 500;\nSELECT * FROM emp WHERE deptno IN (20, 30, 40);\n",
